{
  "version": 2,
  "name": "smart-health-backend",
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/forecast/refresh",
      "schedule": "0 18 * * *"
    }
  ]
}
